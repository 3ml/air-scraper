# Server
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# Encryption (AES-256-GCM) - Must be 32 bytes (64 hex chars) or will be hashed
ENCRYPTION_SECRET=your-32-byte-secret-key-here-change-in-production

# Authentication
AUTH_TOKEN=dev-token-change-in-production
SCRAPER_SECRET=scraper-secret-for-callbacks

# Database
DATABASE_PATH=./data/scraper.db

# Callback endpoints
CALLBACK_URL=https://app.airelite.it/api/scraper/callback
ALERT_WEBHOOK_URL=https://app.airelite.it/api/scraper/alert

# Proxy configuration
PROXY_ENABLED=false
PROXY_POOL_CONFIG=./data/proxies.json

# Browser settings
BROWSER_HEADLESS=true
BROWSER_POOL_SIZE=3
CONTEXT_STORAGE_PATH=./data/contexts

# Performance
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT_MS=300000

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
